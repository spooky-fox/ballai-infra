# Copy to `inventory` (gitignored): `cp inventory.example inventory`
#
# The playbook targets hosts in [github_runners] OR [mac_runners] (union).
#
# --- Bonjour / mDNS (same LAN, DHCP-safe) ---
# Ansible does not “discover” hosts automatically: you set ansible_host to the Mac’s
# multicast DNS name. On the remote Mac: System Settings → General → Sharing → Local hostname,
# or run: scutil --get LocalHostName  → use that value + ".local" (e.g. Marks-MacBook-Pro-2.local).
# The controller must resolve that name (same subnet / IPv6 link-local mDNS is enough for most LANs).
#
# --- Static IP (optional) ---
# Replace ansible_host with an IP if you prefer: ansible_host=10.0.0.5
#
# --- Linux self-hosted (optional) ---
# Add a host with ansible_user set; Monolith installs packages + systemd there.

[github_runners]
localhost ansible_connection=local
marks-runner ansible_host=Marks-MacBook-Pro-2.local ansible_user=mballew

# Legacy: hosts only under mac_runners still run (playbook host pattern is github_runners:mac_runners).
# [mac_runners]
# other ansible_host=10.0.0.12 ansible_user=you
