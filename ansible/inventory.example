# Copy to `inventory` (gitignored): `cp inventory.example inventory`
#
# The playbook targets hosts in [github_runners] OR [mac_runners] (union).
#
# --- Tailscale → LAN fallback ---
# Set ansible_host to the Tailscale MagicDNS name (<hostname>.tail1b3be.ts.net).
# Define ballai_tailscale_host and ballai_fallback_host in host_vars/<name>.yml.
# The playbook probes Tailscale first (port 22, 5s timeout) and falls back to
# the LAN/Bonjour address when unreachable. Leave ballai_fallback_host empty
# for Tailscale-only hosts.
#
# --- Shared machines ---
# Set ballai_runner_shared_machine=true and ballai_runner_use_launchdaemon=true
# in host_vars for machines shared with other users. Skips cask installs, network
# tools, and uses a LaunchDaemon (runs at boot) instead of a LaunchAgent.
#
# --- Passwords ---
# Become passwords live in group_vars/all/vault.yml (ansible-vault encrypted).
# Per-host overrides go in host_vars/<name>.yml (e.g. empty become password for
# NOPASSWD sudo). The .vault-password-file decrypts automatically.
#
# --- mac_runners (legacy) ---
# The play uses hosts: github_runners:mac_runners. Define [mac_runners] even when empty.

[mac_runners]

[github_runners]
m1-mac-mini  ansible_host=m1.tail1b3be.ts.net        ansible_user=ghrunner
ballew-4     ansible_host=bsl.tail1b3be.ts.net       ansible_user=ballew
macbookpro   ansible_host=macbookpro.tail1b3be.ts.net ansible_user=ghrunner
