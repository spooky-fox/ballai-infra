# Copy to `inventory` (gitignored): `cp inventory.example inventory`
#
# The playbook targets hosts in [github_runners] OR [mac_runners] (union).
#
# --- ansible_host: LAN IP vs .local ---
# Use a static LAN IP (below) when mDNS is flaky or `host Name.local` returns NXDOMAIN — that is
# normal: `host`/`dig` use unicast DNS, not Bonjour. SSH/OpenSSH still resolves .local via mDNS on
# macOS when it works. If the other Mac’s DHCP address changes, update this IP or switch to .local.
#
# --- Bonjour / mDNS (optional) ---
# Alternative: ansible_host=Marks-MacBook-Pro-2.local (see scutil --get LocalHostName on remote).
#
# --- Linux self-hosted (optional) ---
# Add hosts with ansible_user set; Monolith installs packages + systemd there.

[github_runners]
localhost ansible_connection=local
marks-runner ansible_host=192.168.1.51 ansible_user=ballew

# Legacy: hosts only under mac_runners still run (playbook host pattern is github_runners:mac_runners).
# [mac_runners]
# other ansible_host=10.0.0.12 ansible_user=you
