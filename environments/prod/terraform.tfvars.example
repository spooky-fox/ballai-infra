# Copy to terraform.tfvars (gitignored) and adjust. Do not commit secrets.

# -----------------------------------------------------------------------------
# CodeBuild-hosted GitHub Actions runners (see README "AWS GitHub Runners")
# -----------------------------------------------------------------------------

# Extra Linux CodeBuild projects for the same repos; distinct runs-on labels, e.g.:
#   codebuild-ballai-gha-ballai-backup-${{ github.run_id }}-${{ github.run_attempt }}
# enable_github_actions_codebuild_backup = true

# Optional extra projects (macOS, alternate Linux, etc.). Default {}.
# macOS: confirm current AWS CodeBuild docs for MAC_ARM image IDs, compute types, and fleets in your
# region before enabling — CodeBuild-managed GHA runner *image* tables may lag general macOS compute.
#
# github_actions_codebuild_extra_repositories = {
#   "ballai-macos" = {
#     repository_name = "ballai"
#     description     = "macOS CodeBuild pool for Ballai (example — set image/environment per AWS)"
#     environment     = "MAC_ARM"
#     compute_type    = "BUILD_GENERAL1_MEDIUM" # replace with value from AWS console / docs
#     image           = "aws/codebuild/..."     # replace with documented macOS image for your region
#   }
# }
